Model SysADLModel ; package SysADL.types { value type Int { } value type Boolean { } value type String { } value type Void { } value type Real { } value type Saldo extends Real { unit = Real dimension = Dinheiro } dimension Dinheiro unit Real { dimension = Dinheiro } value type ID_RFID extends String { } value type VolumeBebida extends Real { unit = ml dimension = Volume } dimension Volume unit ml { dimension = Volume } value type StatusAcesso extends Boolean { } } Requirement ControleAcessoFR ( RF01 ) { text = "O sistema deve validar a entrada e saída de usuários em catracas eletrônicas via cartão RFID ou QR-Code." derive DesempenhoNFR ; Requirement GestaoCreditosFR ( RF02 ) { text = "O sistema deve permitir a compra e recarga de créditos no cartão de identificação em máquinas de autoatendimento." derive VendaAutomaticaItensFR , LiquidacaoFinalFR , SegurancaNFR ; } } Requirement VendaAutomaticaItensFR ( RF03 ) { text = "O sistema deve controlar a liberação de bebidas (latas/garrafas) e lanches prontos em máquinas automáticas após validação do saldo." derive EscalabilidadeNFR ; Requirement DispensacaoVolumeFR ( RF04 ) { text = "O sistema deve controlar torneiras automáticas, permitindo a venda de bebidas por quantidade volumétrica exata." } Requirement PedidosSobDemandaFR ( RF05 ) { text = "O sistema deve registrar pedidos de lanches personalizados feitos em máquinas e gerenciar sua produção." derive ValidacaoColetaFR ; } } Requirement ValidacaoColetaFR ( RF06 ) { text = "O sistema deve liberar a entrega de lanches nos pontos de coleta apenas mediante a apresentação do cartão RFID/QR-Code." } Requirement LiquidacaoFinalFR ( RF07 ) { text = "O sistema deve permitir o fechamento da conta e quitação de despesas remanescentes ao final do uso." } Requirement EscalabilidadeNFR ( RNF01 ) { text = "O sistema deve suportar um grande fluxo de pessoas e múltiplas máquinas operando simultaneamente em arenas ou estádios." } Requirement ConfiabilidadeNFR ( RNF02 ) { text = "O sistema deve garantir a operação contínua e a integridade do saldo do cliente, mesmo em cenários de alta concorrência." } Requirement SegurancaNFR ( RNF03 ) { text = "As transações financeiras e o acesso físico devem ser protegidos contra fraudes e acessos não autorizados." } Requirement ModificabilidadeNFR ( RNF04 ) { text = "A arquitetura deve permitir a instalação do sistema em diferentes configurações (restaurantes, bares ou estádios) com facilidade." } Requirement DesempenhoNFR ( RNF05 ) { text = "O tempo de resposta para validação em catracas e liberação de produtos deve ser mínimo para evitar filas." } package SysADL_ports { import SysADL.types ; port def saidaRFIDOPT { flow out ID_RFID } port def comandoAcessoIPT { flow in StatusAcesso } port def enviaCreditoOPT { flow out Saldo } port def solicitaLiquidacaoOPT { flow out ID_RFID } port def statusOperacaoIPT { flow in Boolean } port def requisicaoVendaOPT { flow out ID_RFID } port def autorizaVendaIPT { flow in Boolean } port def fluxoVolumeOPT { flow out VolumeBebida } port def registroPedidoOPT { flow out ID_RFID } port def validacaoColetaOPT { flow out ID_RFID } port def liberaEntregaIPT { flow in Boolean } port def validaAcessoIPT { flow in ID_RFID } port def autorizaAcessoOPT { flow out StatusAcesso } port def processaFinanceiroIPT { flow in Saldo } port def gestaoSaldoOPT { flow out Boolean } } package SysADL_connectors { import SysADL_ports ; connector def controleAcessoCN { participants : ~ acesso : autorizaAcessoOPT ; ~ comando : comandoAcessoIPT ; } connector def identificacaoCN { participants : ~ validarAcesso : validaAcessoIPT ; ~ leituraRFID : saidaRFIDOPT ; ~ liquidacao : solicitaLiquidacaoOPT ; ~ venda : requisicaoVendaOPT ; ~ pedido : registroPedidoOPT ; ~ coleta : validacaoColetaOPT ; connector def IdentificacaoCN { } } connector def creditoCN { participants : ~ credito : enviaCreditoOPT ; ~ financeiro : processaFinanceiroIPT ; } connector def volumeCN { participants : ~ volume : fluxoVolumeOPT ; ~ financeiro : processaFinanceiroIPT ; } connector def autorizacaoCN { participants : ~ gestao : gestaoSaldoOPT ; ~ status : statusOperacaoIPT ; ~ autoriza : autorizaVendaIPT ; ~ liberacao : liberaEntregaIPT ; } } package SysADL_components { import SysADL_connectors ; }